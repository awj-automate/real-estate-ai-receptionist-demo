# --- Retell (Mode 1: live inbound call) ---
# Create an API key in the Retell dashboard: https://dashboard.retellai.com
RETELL_API_KEY=
# The agent_id of the "Sarah / Jessica Martinez" real estate agent (see README).
RETELL_AGENT_ID=

# --- OpenAI (call summary extraction + build-time sample-call audio) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Google Sheets + Calendar booking (Call Summary buttons) ---
# One service account is shared by both. See the README "Booking destinations"
# section for the Google Cloud setup.
GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_CALENDAR_ID=

# Notes:
# - Modes 2 (Sample Call) and 3 (Dashboard) work with NO keys set.
# - Without RETELL_API_KEY / RETELL_AGENT_ID, Mode 1 is disabled.
# - The Call Summary booking buttons gracefully show "not connected" until the
#   GOOGLE_* vars above are set — they never break the demo.
# - GOOGLE_SHEETS_PRIVATE_KEY: paste the key in double quotes with its literal
#   \n sequences intact (the code converts them at runtime).
# - Copy this file to .env.local for local use, and set the same vars in your
#   Vercel project settings for production.
